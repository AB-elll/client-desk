# ===========================================
# ClientDesk Environment Variables
# Values stored in Bitwarden (AIG-Secrets folder)
# Restore: export BW_SESSION=$(bw unlock --raw)
# ===========================================

# Google Sheets Configuration
CLIENTDESK_SHEET_ID=
# bw get notes clientdesk-sheet-id

# Google OAuth Configuration
GOOGLE_OAUTH_TOKENS_PATH=~/.config/clientdesk/google_tokens.json
GOOGLE_OAUTH_KEYS_PATH=~/.config/gogcli/credentials.json